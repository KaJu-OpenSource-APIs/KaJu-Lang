{
  "name": "kaju",
  "displayName": "kaju",
  "description": "Suporte à linguagem kaju: realce de sintaxe, snippets e configuração de edição (linguagem interpretada, em português).",
  "version": "1.0.0",
  "publisher": "KaJu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KaJu-OpenSource-APIs/KaJu-Lang.git",
    "directory": "editores/vscode-kaju"
  },
  "homepage": "https://github.com/KaJu-OpenSource-APIs/KaJu-Lang",
  "bugs": {
    "url": "https://github.com/KaJu-OpenSource-APIs/KaJu-Lang/issues"
  },
  "keywords": [
    "kaju",
    "português",
    "portuguese",
    "linguagem",
    "interpretada"
  ],
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "icon": "icons/kaju.png",
  "contributes": {
    "languages": [
      {
        "id": "kaju",
        "aliases": [
          "kaju",
          "Kaju"
        ],
        "extensions": [
          ".kaju",
          ".kj"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kaju.png",
          "dark": "./icons/kaju.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "kaju",
        "scopeName": "source.kaju",
        "path": "./syntaxes/kaju.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kaju",
        "path": "./snippets/kaju.json"
      }
    ]
  }
}
